#!/usr/bin/env bash
set -euo pipefail
set -x

if [ "$#" -ne 4 ]; then
  echo "Usage: $0 <S3_ZARR_PATH> <RES_488> <RES_561> <INFERENCE_CHANNEL>"
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
S3_ZARR_PATH="$1"
RES_488="$2"
RES_561="$3"
INFERENCE_CHANNEL="$4"
RAW_SAVE_DIR="/results/raw"
MASK_SAVE_DIR="/results/mask"
PRED_SAVE_DIR="/results/pred"
POSTPROCESSED_SAVE_DIR="/results/postprocessed"
DATA_PROCESS_JSON="/results/data_process.json"

case "$INFERENCE_CHANNEL" in
  488|561) ;;
  *)
    echo "Error: INFERENCE_CHANNEL must be either 488 or 561, got '$INFERENCE_CHANNEL'"
    exit 1
    ;;
esac

PROCESS_START_TIME="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

write_data_process_metadata() {
  local exit_code="$?"
  local run_status="success"
  local metadata_exit_code=0
  local process_end_time

  if [ "$exit_code" -ne 0 ]; then
    run_status="failed"
  fi

  process_end_time="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  set +e
  python3 "$SCRIPT_DIR/generate_data_process.py" \
    --s3-zarr-path "$S3_ZARR_PATH" \
    --res-488 "$RES_488" \
    --res-561 "$RES_561" \
    --inference-channel "$INFERENCE_CHANNEL" \
    --start-date-time "$PROCESS_START_TIME" \
    --end-date-time "$process_end_time" \
    --run-status "$run_status" \
    --exit-code "$exit_code" \
    --output-json "$DATA_PROCESS_JSON"
  metadata_exit_code="$?"
  set -e

  if [ "$exit_code" -eq 0 ] && [ "$metadata_exit_code" -ne 0 ]; then
    exit "$metadata_exit_code"
  fi

  exit "$exit_code"
}
trap write_data_process_metadata EXIT

rm -rf "$PRED_SAVE_DIR" "$POSTPROCESSED_SAVE_DIR"
mkdir -p "$PRED_SAVE_DIR" "$POSTPROCESSED_SAVE_DIR"

# Step 1: Preprocess
python3 "$SCRIPT_DIR/inference_preprocess.py" \
 --zarr "$S3_ZARR_PATH" \
 --channel 488 \
 --res "$RES_488" \
 --raw-save-dir "$RAW_SAVE_DIR/488" \
 --mask-save-dir "$MASK_SAVE_DIR/488"

python3 "$SCRIPT_DIR/inference_preprocess.py" \
 --zarr "$S3_ZARR_PATH" \
 --channel 561 \
 --res "$RES_561" \
 --raw-save-dir "$RAW_SAVE_DIR/561" \
 --mask-save-dir "$MASK_SAVE_DIR/561"

# Step 2: Inference
python3 "$SCRIPT_DIR/inference.py" \
 --raw_tiff_path "${RAW_SAVE_DIR}/${INFERENCE_CHANNEL}" \
 --mask_tiff_path "${MASK_SAVE_DIR}/${INFERENCE_CHANNEL}" \
 --pred_save_dir "$PRED_SAVE_DIR"

# Step 3: Postprocess
python3 "$SCRIPT_DIR/postprocess_masks.py" \
 --input_path "$PRED_SAVE_DIR" \
 --output_dir "$POSTPROCESSED_SAVE_DIR" \
 --raw_base_dir "/results/raw" \
 --kernel_size 3 \
 --raw_intensity_percentile 75 \
 --summary_percentile 75
